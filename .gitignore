# Python
.venv/
__pycache__/
*.pyc

# macOS
.DS_Store

# Office temp/lock files (created while a .docx/.xlsx is open)
~$*

# mdBook documentation site — both are generated:
#   book/src   by tools/build_book.py (mirror of docs/)
#   book/book  by `mdbook build`
/book/src/
/book/book/

# run logs
/logs/

# Large derived analysis artifact (per-model factor scores over all 28k timepoints,
# ~36 MB). Regenerate in MATLAB with extractCategoryFactors; kept Dropbox-only.
/analysis/extracted_factors.mat

# plotFactorScores exports: keep the lightweight PNGs in git; the vector SVGs are large
# (~6 MB, the force-directed one alone is ~2.6 MB) and regenerable, so keep them Dropbox-only.
/matlab/figures/*.svg

# Reference PDFs — copyrighted publisher/preprint PDFs of the papers behind each
# model. Kept in Dropbox only, excluded from git (the docs link to public arXiv/DOI
# URLs instead, which resolve on the web book). See PDFs/README.md.
/PDFs/

# Annotation derivatives — kept in Dropbox only, excluded from git by choice.
# The docs site does NOT need them (it uses analysis/figures + analysis/web).
# Regenerate from the media with the pipeline; or host the dataset on OSF/Zenodo.
/annotations/

# --------------------------------------------------------------------------
# Stimulus MEDIA — never commit to GitHub. Two reasons:
#   (1) size: many files exceed GitHub's 100 MB hard per-file limit (~11 GB total);
#   (2) copyright: spacetop clips, Narratives audio, and Kung Fury are others' IP.
# These live in Dropbox; git tracks only the metadata (manifest.csv, SOURCES.md,
# lexicon CSVs, the small text story). The docs site never needs the media.
data/**/*.mp4
data/**/*.mkv
data/**/*.mov
data/**/*.m4v
data/**/*.avi
data/**/*.webm
data/**/*.wav
data/**/*.mp3
data/**/*.m4a
data/**/*.aac
data/**/*.flac
data/**/*.ogg
